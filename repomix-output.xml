  .city-name{ font-size:2.3rem; } .temp-big{ font-size:4.4rem; } .w-icon{ font-size:95px; }
  .details-grid{ grid-template-columns:repeat(2,1fr); } .weather-hero{ gap:22px; }
}
@media(max-width:600px){
  .city-name{ font-size:2rem; } .temp-big{ font-size:3.7rem; } .w-icon{ font-size:80px; }
  .char-svg-wrap{ transform:scale(2.4); margin:64px 0; }
  .logo-name{ font-size:1.75rem; } .search-row input{ font-size:1.1rem; }
}
