<file path="frontend/character.js">
const Character = (() => {

  let state = {
    gender  : 'm',
    skin    : 'light',
    hair    : 'brown',
    outfit  : 'normal',
    isNight : false,
  };

  const SKIN = {
    light  : { face:'#FFDBB4', shadow:'#E8B88A', neck:'#F1C27D' },
    medium : { face:'#cba378', shadow:'#A0672E', neck:'#B57531' },
    dark   : { face:'#5C3317', shadow:'#3D200D', neck:'#4B2912' },
  };
  
  const HAIR = {
    black  : '#1C1008',
    brown  : '#6B3A2A',
    blonde : '#E9C46A',
    red    : '#B22222',
    gray   : '#888888',
  };

  function buildSVG() {
    const sk  = SKIN[state.skin]  || SKIN.light;
    const hr  = HAIR[state.hair]  || HAIR.brown;
    const isF = state.gender === 'f';
    const out = state.outfit;

    const clothes = {
      body  : outfitBodyColor(out),
      pants : outfitPantsColor(out),
      acc   : outfitAccessory(out, isF),
    };

    return `
<svg class="char-svg" width="140" height="200" viewBox="0 0 140 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Umbră la picioare -->
  <ellipse cx="70" cy="190" rx="35" ry="6" fill="rgba(0,0,0,0.1)"/>

  <!-- PICIOARE -->
  <rect x="48" y="145" width="16" height="42" rx="8" fill="${clothes.pants}" />
  <rect x="76" y="145" width="16" height="42" rx="8" fill="${clothes.pants}" />
  <path d="M48,182 h18 q2,0 2,4 t-2,4 h-18 q-4,0 -4,-4 t4,-4z" fill="#333"/>
  <path d="M76,182 h18 q2,0 2,4 t-2,4 h-18 q-4,0 -4,-4 t4,-4z" fill="#333"/>

  <!-- CORP -->
  ${buildBody(sk, clothes, isF, out)}

  <!-- ACCESORIU METEO -->
  ${clothes.acc}

  <!-- CAP -->
  ${buildHead(sk, hr, isF, out)}
</svg>`.trim();
  }

  function buildBody(sk, cl, isF, out) {
    let body;
    if (isF) {
      body = `<path d="M40,152 L100,152 L85,100 L55,100 Z" fill="${cl.body}"/>
              <path d="M55,100 L70,115 L85,100" fill="rgba(0,0,0,0.05)"/>`;
    } else {
      body = `<rect x="40" y="100" width="60" height="52" rx="10" fill="${cl.body}"/>`;
    }

    const armL = `<rect x="25" y="102" width="15" height="40" rx="7" fill="${cl.body}"/>
    <circle cx="32.5" cy="142" r="8" fill="${sk.face}"/>`;
    const armR = `<rect x="100" y="102" width="15" height="40" rx="7" fill="${cl.body}"/>
   <circle cx="107.5" cy="142" r="8" fill="${sk.face}"/>`;

    const scarf = (out === 'winter' || out === 'heavy-winter') 
   ? `<path d="M50,95 h40 q5,0 5,8 t-5,8 h-40 q-5,0 -5,-8 t5,-8" fill="#d63031"/>` : '';

    return `<rect x="63" y="90" width="14" height="15" fill="${sk.neck}"/>${armL}${armR}${body}${scarf}`;
  }

  function buildHead(sk, hr, isF, out) {
    const faceShape = isF 
      ? `<path d="M40,65 q0,-30 30,-30 t30,30 q0,25 -30,25 t-30,-25" fill="${sk.face}"/>`
      : `<rect x="40" y="35" width="60" height="55" rx="25" fill="${sk.face}"/>`;

    const eyes = isF 
      ? `<!-- Ochi Fată -->
         <circle cx="58" cy="62" r="4" fill="#333"/>
         <circle cx="82" cy="62" r="4" fill="#333"/>
         <path d="M54,58 q2,-4 6,0" fill="none" stroke="#333" stroke-width="1.5"/>
         <path d="M78,58 q2,-4 6,0" fill="none" stroke="#333" stroke-width="1.5"/>`
      : `<!-- Ochi Băiat -->
         <circle cx="58" cy="62" r="3.5" fill="#333"/>
         <circle cx="82" cy="62" r="3.5" fill="#333"/>`;

    const hair = isF 
      ? `<!-- Păr Fată -->
         <path d="M35,65 q0,-40 35,-40 t35,40 v30 q0,5 -5,5 t-5,-5 v-25 h-50 v25 q0,5 -5,5 t-5,-5 z" fill="${hr}"/>`
      : `<!-- Păr Băiat -->
         <path d="M40,45 q0,-20 30,-20 t30,20 l5,5 h-70 z" fill="${hr}"/>`;

    const mouth = `<path d="M62,78 q8,5 16,0" fill="none" stroke="#e17055" stroke-width="2" stroke-linecap="round"/>`;

    return `${hair}${faceShape}${eyes}${mouth}`;
  }

  function outfitAccessory(out, isF) {
    if (out === 'jacket') {
      return `<path d="M25,120 L25,150 M15,125 q10,-15 20,0" stroke="#0984e3" stroke-width="3" fill="none"/>`;
    }
    if (out === 'summer') {
      return `<rect x="52" y="58" width="14" height="6" rx="2" fill="rgba(0,0,0,0.6)"/>
              <rect x="74" y="58" width="14" height="6" rx="2" fill="rgba(0,0,0,0.6)"/>`;
    }
    return '';
  }

  function outfitBodyColor(out) {
    const map = { summer:'#fab1a0', light:'#81ecec', normal:'#74b9ff', jacket:'#55efc4', winter:'#0984e3', 'heavy-winter':'#2d3436' };
    return map[out] || '#74b9ff';
  }

  function outfitPantsColor(out) {
    return '#2d3436';
  }


  function render() {
    const el = document.getElementById('charSvg');
    if (el) el.innerHTML = buildSVG();
  }

  return {
    render,
    setGender: (g) => { state.gender = g; render(); },
    setSkin: (s) => { state.skin = s; render(); },
    setHair: (h) => { state.hair = h; render(); },
    updateForWeather: (data) => {
      state.outfit = data.advice.outfit;
      state.isNight = data.isNight;
      render();
      const b = document.getElementById('bubbleText');
      if (b) b.textContent = (data.isNight ? "E noapte, odihnește-te!" : "Uite ce vreme faină!");
    }
  };
})();

function setGender(g) { Character.setGender(g); }
function setSkin(s) { Character.setSkin(s); }
function setHair(h) { Character.setHair(h); }
