              <span class="det-lbl">Umiditate</span>
              <span class="det-val" id="dHumidity">—</span>
            </div>
            <div class="card det-card">
              <span class="det-ico">💨</span>
              <span class="det-lbl">Vânt</span>
              <span class="det-val" id="dWind">—</span>
            </div>
            <div class="card det-card">
              <span class="det-ico">🌡️</span>
              <span class="det-lbl">Se simte ca</span>
              <span class="det-val" id="dFeels">—</span>
            </div>
            <div class="card det-card">
              <span class="det-ico">🌅</span>
              <span class="det-lbl">Răsărit</span>
              <span class="det-val" id="dSunrise">—</span>
            </div>
            <div class="card det-card">
              <span class="det-ico">🌇</span>
              <span class="det-lbl">Apus</span>
              <span class="det-val" id="dSunset">—</span>
            </div>
            <div class="card det-card">
              <span class="det-ico">👁️</span>
              <span class="det-lbl">Vizibilitate</span>
              <span class="det-val" id="dVis">—</span>
            </div>
          </div>

          <div class="card advice-card" id="adviceCard">
            <div class="advice-ico" id="advIco">👔</div>
            <div class="advice-body">
              <div class="advice-title">Sfatul prietenului tău:</div>
              <div class="advice-text" id="advText">—</div>
            </div>
          </div>

        </div>

      </main>
    </div>
  </div>

  <div class="toast" id="toast"></div>
  <script src="weather.js"></script>
  <script src="character.js"></script>
  <script src="background.js"></script>
